        <UserObject id="rel_42" label="多張照片" parentTable="VisitTaskExecution" parentColumn="TaskExecutionId" childTable="VisitTaskPhoto" childColumn="TaskExecutionId"><mxCell edge="1" parent="1" source="row_VisitTaskExecution_TaskExecutionId" target="row_VisitTaskPhoto_TaskExecutionId" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=18;html=1;endArrow=ERmany;endFill=0;startArrow=ERone;startFill=0;strokeWidth=1.5;strokeColor=#b85450;fontSize=11;labelBackgroundColor=#ffffff;"><mxGeometry relative="1" as="geometry"/></mxCell></UserObject>
        <mxCell id="note_legend" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fillColor=#f5f5f5;strokeColor=#666666;fontSize=13;align=left;verticalAlign=top;spacing=10;" value="&lt;b&gt;欄位級關聯圖例&lt;/b&gt;&lt;br&gt;每條線直接連接實際 PK／FK 欄位。&lt;br&gt;直線端＝1；鳥腳端＝多筆；圓圈＋直線＝FK 可空（0..1）。&lt;br&gt;PK 主鍵　FK 外鍵　UK 唯一鍵　UQ1 同組複合唯一鍵　UQ? 待確認。" vertex="1"><mxGeometry x="60" y="1800" width="760" height="200" as="geometry"/></mxCell>
        <mxCell id="note_rules" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;align=left;verticalAlign=top;spacing=10;" value="&lt;b&gt;0722 核心規則&lt;/b&gt;&lt;br&gt;• UserAccount：EmployeeId／DealerId 二擇一；每家經銷商一個登入帳號。&lt;br&gt;• Passkey 私鑰與 Face ID 不進資料庫，只保存 WebAuthn 公鑰。&lt;br&gt;• StoreVisit 可由業務或經銷商建立，建立／更新者指向 UserAccount。&lt;br&gt;• 實銷有 SellOutDate；陳列無獨立業務日期。&lt;br&gt;• 經銷商自填不執行公司任務；任務只由 Employee 完成。" vertex="1"><mxGeometry x="860" y="1800" width="850" height="230" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
