        <mxCell id="1" parent="0" />
        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;erDiagram\n    Employee__員工 {\n        bigint EmployeeId__員工識別碼 PK\n        nvarchar EmployeeNo__員工編號 UK\n        nvarchar EmployeeName__員工姓名\n        datetime2 HireDate__到職日期\n        datetime2 TerminationDate__離職日期\n        varchar EmploymentStatus__在職狀態\n        bit IsLoginEnabled__是否允許登入\n    }\n\n    EmployeePositionHistory__員工職級歷史 {\n        bigint EmployeePositionHistoryId__員工職級歷史識別碼 PK\n        bigint EmployeeId__員工識別碼 FK\n        varchar PositionLevel__職級\n        datetime2 StartDateTime__生效開始時間\n        datetime2 EndDateTime__生效結束時間\n        nvarchar ChangeReason__異動原因\n        datetime2 CreatedAt__建立時間\n        bigint CreatedByEmployeeId__建立者員工識別碼 FK\n    }\n\n    OrganizationUnit__組織單位 {\n        bigint OrgUnitId__組織單位識別碼 PK\n        varchar OrgUnitCode__組織單位代碼 UK\n        nvarchar OrgUnitName__組織單位名稱\n        bit IsActive__是否啟用\n    }\n\n    EmployeeOrgAssignmentHistory__員工組織歸屬歷史 {\n        bigint EmployeeOrgAssignmentId__員工組織歸屬識別碼 PK\n        bigint EmployeeId__員工識別碼 FK\n        bigint OrgUnitId__組織單位識別碼 FK\n        datetime2 StartDateTime__生效開始時間\n        datetime2 EndDateTime__生效結束時間\n        nvarchar ChangeReason__異動原因\n        datetime2 CreatedAt__建立時間\n        bigint CreatedByEmployeeId__建立者員工識別碼 FK\n    }\n\n    Dealer__經銷商 {\n        bigint DealerId__經銷商識別碼 PK\n        varchar DealerCode__經銷商代碼 UK\n        nvarchar DealerName__經銷商名稱\n        varchar DealerStatus__經銷商狀態\n        datetime2 CreatedAt__建立時間\n    }\n\n    DealerAssignmentHistory__經銷商負責人歷史 {\n        bigint DealerAssignmentId__經銷商指派識別碼 PK\n        bigint DealerId__經銷商識別碼 FK\n        bigint EmployeeId__負責員工識別碼 FK\n        datetime2 StartDateTime__生效開始時間\n        datetime2 EndDateTime__生效結束時間\n        nvarchar ChangeReason__異動原因\n        datetime2 CreatedAt__建立時間\n        bigint CreatedByEmployeeId__建立者員工識別碼 FK\n    }\n\n    Sales__銷售紀錄 {\n        bigint SaleId__銷售識別碼 PK\n        bigint DealerId__經銷商識別碼 FK\n        datetime2 SaleDateTime__銷售日期時間\n        decimal Amount__銷售金額\n        bigint DealerAssignmentId__經銷商指派識別碼 FK\n        bigint ResponsibleEmployeeId__負責員工識別碼 FK\n        datetime2 CreatedAt__建立時間\n        bigint CreatedByEmployeeId__建立者員工識別碼 FK\n        datetime2 UpdatedAt__更新時間\n        bigint UpdatedByEmployeeId__更新者員工識別碼 FK\n    }\n\n    Product__產品 {\n        bigint ProductId__產品識別碼 PK\n        varchar ProductCode__產品代碼 UK\n        nvarchar ProductName__產品名稱\n        nvarchar CategoryLevel1__第一層產品分類\n        nvarchar CategoryLevel2__第二層產品分類\n        bit IsActive__是否啟用\n        datetime2 CreatedAt__建立時間\n    }\n\n    ImportBatch__資料匯入批次 {\n        bigint ImportBatchId__匯入批次識別碼 PK\n        varchar ImportType__匯入類型\n        char DataMonth__資料月份\n        date DataDate__資料日期\n        nvarchar OriginalFileName__原始檔名\n        nvarchar StoredFileName__儲存檔名\n        nvarchar StoredFilePath__儲存檔案路徑\n        varchar FileHash__檔案雜湊值\n        bigint FileSize__檔案大小\n        varchar ImportStatus__匯入狀態\n        bigint ReplacedBatchId__被取代批次識別碼 FK\n        int TotalRowCount__總資料列數\n        int SuccessRowCount__成功資料列數\n        int ErrorRowCount__錯誤資料列數\n        nvarchar ErrorSummary__錯誤摘要\n        nvarchar ErrorReportPath__錯誤報告路徑\n        datetime2 ImportedAt__匯入時間\n        bigint ImportedByEmployeeId__匯入者員工識別碼 FK\n    }\n\n    MonthlyOpeningInventoryDetail__每月期初庫存明細 {\n        bigint OpeningInventoryDetailId__期初庫存明細識別碼 PK\n        bigint ImportBatchId__匯入批次識別碼 FK\n        int SourceRowNumber__來源資料列號碼\n        bigint DealerId__經銷商識別碼 FK\n        bigint ProductId__產品識別碼 FK\n        int OpeningQuantity__期初庫存數量\n    }\n\n    SellInTransaction__進貨交易 {\n        bigint SellInTransactionId__進貨交易識別碼 PK\n        bigint ImportBatchId__匯入批次識別碼 FK\n        int SourceRowNumber__來源資料列號碼\n        bigint DealerId__經銷商識別碼 FK\n        bigint ProductId__產品識別碼 FK\n        varchar SalesDocumentNo__銷售文件號碼\n        varchar SalesDocumentItemNo__銷售文件項次\n        varchar InvoiceNo__發票號碼\n        date OrderDate__訂單日期\n        date BillingDate__開立帳單日期\n        date InvoiceDate__發票日期\n        date InventoryEffectiveDate__庫存生效日期\n        decimal Quantity__交易數量\n        varchar TransactionType__交易類型\n        varchar TransactionStatus__交易狀態\n        varchar ReviewStatus__審核狀態\n        datetime2 CreatedAt__建立時間\n        datetime2 UpdatedAt__更新時間\n    }\n\n    StoreVisit__巡店紀錄 {\n        bigint StoreVisitId__巡店識別碼 PK\n        bigint DealerId__經銷商識別碼 FK\n        bigint DealerAssignmentId__經銷商指派識別碼 FK\n        bigint ResponsibleEmployeeId__負責員工識別碼 FK\n        bigint PreviousStoreVisitId__前次巡店識別碼 FK\n        datetime2 VisitDateTime__巡店日期時間\n        datetime2 PeriodStartDateTime__統計期間開始時間\n        datetime2 PeriodEndDateTime__統計期間結束時間\n        varchar VisitStatus__巡店狀態\n        datetime2 CreatedAt__建立時間\n        bigint CreatedByEmployeeId__建立者員工識別碼 FK\n        datetime2 UpdatedAt__更新時間\n        bigint UpdatedByEmployeeId__更新者員工識別碼 FK\n    }\n\n    StoreVisitProductDetail__巡店產品明細 {\n        bigint StoreVisitProductDetailId__巡店產品明細識別碼 PK\n        bigint StoreVisitId__巡店識別碼 FK\n        bigint ProductId__產品識別碼 FK\n        decimal SellOutQuantity__銷售出庫數量\n        int DisplayQuantity__陳列數量\n        bit IsSellOutChecked__是否確認銷售出庫\n        bit IsDisplayChecked__是否確認陳列數量\n        datetime2 CreatedAt__建立時間\n        datetime2 UpdatedAt__更新時間\n    }\n\n    Employee__員工 ||--o{ EmployeePositionHistory__員工職級歷史 : \&quot;Employee.EmployeeId__員工識別碼 to EmployeePositionHistory.EmployeeId__員工識別碼\&quot;\n    Employee__員工 ||--o{ EmployeePositionHistory__員工職級歷史 : \&quot;Employee.EmployeeId__員工識別碼 to EmployeePositionHistory.CreatedByEmployeeId__建立者員工識別碼\&quot;\n\n    Employee__員工 ||--o{ EmployeeOrgAssignmentHistory__員工組織歸屬歷史 : \&quot;Employee.EmployeeId__員工識別碼 to EmployeeOrgAssignmentHistory.EmployeeId__員工識別碼\&quot;\n    OrganizationUnit__組織單位 ||--o{ EmployeeOrgAssignmentHistory__員工組織歸屬歷史 : \&quot;OrganizationUnit.OrgUnitId__組織單位識別碼 to EmployeeOrgAssignmentHistory.OrgUnitId__組織單位識別碼\&quot;\n    Employee__員工 ||--o{ EmployeeOrgAssignmentHistory__員工組織歸屬歷史 : \&quot;Employee.EmployeeId__員工識別碼 to EmployeeOrgAssignmentHistory.CreatedByEmployeeId__建立者員工識別碼\&quot;\n\n    Dealer__經銷商 ||--o{ DealerAssignmentHistory__經銷商負責人歷史 : \&quot;Dealer.DealerId__經銷商識別碼 to DealerAssignmentHistory.DealerId__經銷商識別碼\&quot;\n    Employee__員工 ||--o{ DealerAssignmentHistory__經銷商負責人歷史 : \&quot;Employee.EmployeeId__員工識別碼 to DealerAssignmentHistory.EmployeeId__負責員工識別碼\&quot;\n    Employee__員工 ||--o{ DealerAssignmentHistory__經銷商負責人歷史 : \&quot;Employee.EmployeeId__員工識別碼 to DealerAssignmentHistory.CreatedByEmployeeId__建立者員工識別碼\&quot;\n\n    Dealer__經銷商 ||--o{ Sales__銷售紀錄 : \&quot;Dealer.DealerId__經銷商識別碼 to Sales.DealerId__經銷商識別碼\&quot;\n    DealerAssignmentHistory__經銷商負責人歷史 ||--o{ Sales__銷售紀錄 : \&quot;DealerAssignmentHistory.DealerAssignmentId__經銷商指派識別碼 to Sales.DealerAssignmentId__經銷商指派識別碼\&quot;\n    Employee__員工 ||--o{ Sales__銷售紀錄 : \&quot;Employee.EmployeeId__員工識別碼 to Sales.ResponsibleEmployeeId__負責員工識別碼\&quot;\n    Employee__員工 ||--o{ Sales__銷售紀錄 : \&quot;Employee.EmployeeId__員工識別碼 to Sales.CreatedByEmployeeId__建立者員工識別碼\&quot;\n    Employee__員工 ||--o{ Sales__銷售紀錄 : \&quot;Employee.EmployeeId__員工識別碼 to Sales.UpdatedByEmployeeId__更新者員工識別碼\&quot;\n\n    Employee__員工 ||--o{ ImportBatch__資料匯入批次 : \&quot;Employee.EmployeeId__員工識別碼 to ImportBatch.ImportedByEmployeeId__匯入者員工識別碼\&quot;\n    ImportBatch__資料匯入批次 o|--o{ ImportBatch__資料匯入批次 : \&quot;ImportBatch.ImportBatchId__匯入批次識別碼 to ImportBatch.ReplacedBatchId__被取代批次識別碼\&quot;\n\n    ImportBatch__資料匯入批次 ||--o{ MonthlyOpeningInventoryDetail__每月期初庫存明細 : \&quot;ImportBatch.ImportBatchId__匯入批次識別碼 to MonthlyOpeningInventoryDetail.ImportBatchId__匯入批次識別碼\&quot;\n    Dealer__經銷商 ||--o{ MonthlyOpeningInventoryDetail__每月期初庫存明細 : \&quot;Dealer.DealerId__經銷商識別碼 to MonthlyOpeningInventoryDetail.DealerId__經銷商識別碼\&quot;\n    Product__產品 ||--o{ MonthlyOpeningInventoryDetail__每月期初庫存明細 : \&quot;Product.ProductId__產品識別碼 to MonthlyOpeningInventoryDetail.ProductId__產品識別碼\&quot;\n\n    ImportBatch__資料匯入批次 ||--o{ SellInTransaction__進貨交易 : \&quot;ImportBatch.ImportBatchId__匯入批次識別碼 to SellInTransaction.ImportBatchId__匯入批次識別碼\&quot;\n    Dealer__經銷商 ||--o{ SellInTransaction__進貨交易 : \&quot;Dealer.DealerId__經銷商識別碼 to SellInTransaction.DealerId__經銷商識別碼\&quot;\n    Product__產品 ||--o{ SellInTransaction__進貨交易 : \&quot;Product.ProductId__產品識別碼 to SellInTransaction.ProductId__產品識別碼\&quot;\n\n    Dealer__經銷商 ||--o{ StoreVisit__巡店紀錄 : \&quot;Dealer.DealerId__經銷商識別碼 to StoreVisit.DealerId__經銷商識別碼\&quot;\n    DealerAssignmentHistory__經銷商負責人歷史 ||--o{ StoreVisit__巡店紀錄 : \&quot;DealerAssignmentHistory.DealerAssignmentId__經銷商指派識別碼 to StoreVisit.DealerAssignmentId__經銷商指派識別碼\&quot;\n    Employee__員工 ||--o{ StoreVisit__巡店紀錄 : \&quot;Employee.EmployeeId__員工識別碼 to StoreVisit.ResponsibleEmployeeId__負責員工識別碼\&quot;\n    Employee__員工 ||--o{ StoreVisit__巡店紀錄 : \&quot;Employee.EmployeeId__員工識別碼 to StoreVisit.CreatedByEmployeeId__建立者員工識別碼\&quot;\n    Employee__員工 ||--o{ StoreVisit__巡店紀錄 : \&quot;Employee.EmployeeId__員工識別碼 to StoreVisit.UpdatedByEmployeeId__更新者員工識別碼\&quot;\n    StoreVisit__巡店紀錄 o|--o{ StoreVisit__巡店紀錄 : \&quot;StoreVisit.StoreVisitId__巡店識別碼 to StoreVisit.PreviousStoreVisitId__前次巡店識別碼\&quot;\n\n    StoreVisit__巡店紀錄 ||--o{ StoreVisitProductDetail__巡店產品明細 : \&quot;StoreVisit.StoreVisitId__巡店識別碼 to StoreVisitProductDetail.StoreVisitId__巡店識別碼\&quot;\n    Product__產品 ||--o{ StoreVisitProductDetail__巡店產品明細 : \&quot;Product.ProductId__產品識別碼 to StoreVisitProductDetail.ProductId__產品識別碼\&quot;\n&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="jXigfcoCjcQqczEGit24-535">
